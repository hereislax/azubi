# Django
SECRET_KEY=ersetze-mich-mit-einem-langen-zufaelligen-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,azubi.deine-domain.de,www.azubi.deine-domain.de
CSRF_TRUSTED_ORIGINS=https://azubi.deine-domain.de

# URL der Webseite für Benachrichtigungen u.ä.
SITE_BASE_URL=https://azubi.deine-domain.de

# Datenbank
DB_NAME=azubi
DB_USER=azubi
DB_PASSWORD=sicheres-passwort
DB_HOST=db
DB_PORT=5432

# E-Mail (SMTP)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=Azubi-Portal <portal@deine-domain.de>
DEFAULT_REPLY_TO_EMAIL=

# Paperless-Container (nur falls Paperless im selben docker-compose läuft)
PAPERLESS_PUBLIC_URL=https://paperless.deine-domain.de
PAPERLESS_SECRET_KEY=ersetze-mich-mit-einem-langen-zufaelligen-string
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=sicheres-passwort

# Paperless-ngx (Fallback – bevorzugt über Einstellungen > Paperless-ngx konfigurieren)
PAPERLESS_URL=http://paperless:8000
PAPERLESS_API_KEY=

# Backup
# Bind-Mount-Pfad für lokale Backups (DB-Dumps + Media-Tarballs).
# Sollte auf einer eigenen Partition liegen oder per restic off-site gespiegelt werden.
BACKUP_DIR=/var/backups/azubi
# Wie viele tägliche Backups mindestens vorgehalten werden (vor GFS-Rotation)
BACKUP_KEEP_DAILY=7
# Empfänger-Adresse(n) für Backup-Fehler-Mails (kommasepariert)
BACKUP_ALERT_EMAILS=ops@deine-domain.de

# Off-Site-Backup via restic
# SFTP-Beispiel:
#   RESTIC_REPOSITORY=sftp:backup-user@nas.local:/volume1/backups/azubi
# Lokal-gemounteter SMB-/NFS-Share (Pfad innerhalb des Containers):
#   RESTIC_REPOSITORY=/restic-target
# S3-kompatibel (MinIO/TrueNAS):
#   RESTIC_REPOSITORY=s3:https://minio.local:9000/azubi
RESTIC_REPOSITORY=
RESTIC_PASSWORD_FILE=/secrets/restic.key
# Verzeichnis mit restic.key (und ggf. ssh_id für SFTP). Wird read-only ins
# celery_worker als /secrets gemountet.
RESTIC_SECRETS_DIR=./docker/restic-secrets